# ===== NEXT.JS PUBLIC CONFIG =====
NEXT_PUBLIC_LATEST_POINTER_URL=/snapshots/universe_v0.1_public/_public/latest.json
NEXT_PUBLIC_MINIO_PUBLIC_ROOT=/snapshots/
NEXT_PUBLIC_SNAPSHOT_LATEST_URL=/snapshots/universe_v0.1_public/_public/latest.json
NEXT_PUBLIC_SNAPSHOT_BASE_URL=/snapshots
NEXT_PUBLIC_MINIO_BASE=/snapshots
NEXT_PUBLIC_LATEST_POINTER=universe_v0.1_public/_public/latest.json
NEXT_PUBLIC_BUCKET=universe_v0.1_public

# ===== SERVER-SIDE MINIO =====
SNAPSHOT_LATEST_URL=http://localhost:9002/gpti-snapshots/universe_v0.1_public/_public/latest.json
MINIO_INTERNAL_ROOT=http://localhost:9002/gpti-snapshots/
MINIO_INTERNAL_ENDPOINT=http://localhost:9002

# Dedicated MinIO S3 API endpoint for server-side writes.
# Expose this endpoint via local reverse proxy (see ops/nginx/minio-api-9003.conf).
MINIO_ENDPOINT=http://127.0.0.1:9003
MINIO_BUCKET=gtixt-data

# Keep credentials out of repository: use *_FILE runtime secrets.
MINIO_ACCESS_KEY_FILE=/run/secrets/gpti-site/minio_access_key
MINIO_SECRET_KEY_FILE=/run/secrets/gpti-site/minio_secret_key

# ALS service-to-service auth (scoped) via runtime secret file.
ALS_API_TOKEN_FILE=/run/secrets/gpti-site/als_api_token
ALS_SERVICE_SCOPE=autonomous_lab_read

# ===== CACHE CONFIG =====
NEXT_PUBLIC_FIRM_CACHE_TTL_MS=60000
NEXT_PUBLIC_DISABLE_EVIDENCE_EXTRACT=0

# ===== DATABASE =====
DATABASE_URL_FILE=/run/secrets/gpti-site/database_url

# ===== AI CONFIG =====
AI_BACKEND=ollama
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# OpenAI API Key (Optional - for GPT-4, GPT-5 models)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY_FILE=/run/secrets/gpti-site/openai_api_key

# ===== SLACK ALERTING =====
# Slack webhook URL for critical alerts
SLACK_WEBHOOK_URL_FILE=/run/secrets/gpti-site/slack_webhook_url

# Optional OpenAI-compatible API key (OpenRouter/vLLM gateway)
OSS_LLM_API_KEY_FILE=/run/secrets/gpti-site/oss_llm_api_key

# Optional legacy LLM provider key
LLM_API_KEY_FILE=/run/secrets/gpti-site/llm_api_key

# ===== REDIS =====
# Use one of the two approaches below
# REDIS_URL=redis://:password@host:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD_FILE=/run/secrets/gpti-site/redis_password
REDIS_DB=0

# ===== SMTP / BREVO =====
SMTP_PASS_FILE=/run/secrets/gpti-site/smtp_pass
BREVO_API_KEY_FILE=/run/secrets/gpti-site/brevo_api_key
