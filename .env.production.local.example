# Production Deployment - Frontend Environment
# File: /opt/gpti/gpti-site/.env.production.local
# NEVER COMMIT THIS FILE

# MinIO Data Sources (Production URLs - public)
NEXT_PUBLIC_LATEST_POINTER_URL=https://data.gtixt.com/gpti-snapshots/universe_v0.1_public/_public/latest.json
NEXT_PUBLIC_MINIO_PUBLIC_ROOT=https://data.gtixt.com/gpti-snapshots/

# Slack Webhook for Alerts (Keep this secret!)
SLACK_WEBHOOK_URL_FILE=/run/secrets/gpti-site/slack_webhook_url

# Database DSN via runtime secret file
DATABASE_URL_FILE=/run/secrets/gpti-site/database_url

# OpenAI / OSS API keys via runtime secret files
OPENAI_API_KEY_FILE=/run/secrets/gpti-site/openai_api_key
OSS_LLM_API_KEY_FILE=/run/secrets/gpti-site/oss_llm_api_key
LLM_API_KEY_FILE=/run/secrets/gpti-site/llm_api_key
REDIS_PASSWORD_FILE=/run/secrets/gpti-site/redis_password
SMTP_PASS_FILE=/run/secrets/gpti-site/smtp_pass
BREVO_API_KEY_FILE=/run/secrets/gpti-site/brevo_api_key

# Data Sync Configuration (Optional - use defaults if not needed)
# NEXT_PUBLIC_POLL_INTERVAL=300000
# NEXT_PUBLIC_CACHE_TTL=1800000
# NEXT_PUBLIC_OFFLINE_MAX_AGE_DAYS=7

# ALS service-to-service scope (token read from mounted secret file)
ALS_API_TOKEN_FILE=/run/secrets/gpti-site/als_api_token
ALS_SERVICE_SCOPE=autonomous_lab_read

# Dedicated local MinIO API endpoint (reverse proxy -> MinIO S3 API)
MINIO_ENDPOINT=http://127.0.0.1:9003
MINIO_BUCKET=gtixt-data

# MinIO credentials via mounted secret files
MINIO_ACCESS_KEY_FILE=/run/secrets/gpti-site/minio_access_key
MINIO_SECRET_KEY_FILE=/run/secrets/gpti-site/minio_secret_key
